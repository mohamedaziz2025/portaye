# Portaye Environment Configuration
# Copy this file to .env and update values as needed

# Environment
NODE_ENV=production

# Nginx Configuration
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# API Keys
CALENDLY_TOKEN=your_calendly_token_here

# Security
# Enable HSTS (HTTP Strict Transport Security)
ENABLE_HSTS=true

# Performance
# Cache control max age in seconds (default 1 year for static assets)
CACHE_MAX_AGE=31536000

# Logging
LOG_LEVEL=info
